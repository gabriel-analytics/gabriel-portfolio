# Notion Integration — Lead Capture
# 1. Create a Notion integration at https://www.notion.so/my-integrations
# 2. Share the leads database with the integration
# 3. Copy the integration token and database ID below
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_LEADS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Site URL — used for OG image generation
NEXT_PUBLIC_SITE_URL=https://gabrielpacheco-portfolio.vercel.app

# Resend — Lead Notification Email (optional but recommended)
# 1. Sign up free at https://resend.com (no credit card, no domain needed to
#    start — the default onboarding@resend.dev sender works out of the box)
# 2. Create an API key at https://resend.com/api-keys
# 3. Paste it below. LEAD_NOTIFICATION_EMAIL is optional — defaults to
#    gabrielmepv@gmail.com if not set.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFICATION_EMAIL=gabrielmepv@gmail.com
